{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "instruct": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "title": "Model",
          "description": "HuggingFace model path for instruct/LLM"
        },
        "apiKey": {
          "type": "string",
          "title": "API Key",
          "description": "API key for vLLM instruct service authentication. If empty, authentication is disabled.",
