FROM registry.access.redhat.com/ubi9/ubi:9.8 AS builder

ARG CMD_VERSION
ARG GITCOMMIT
ARG BUILDDATE
ARG BUILDTAGS
ARG GO_VERSION=1.25.10

WORKDIR /go/src/github.com/project-ai-services/ai-services

USER root

RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-ppc64le.tar.gz -o go.tar.gz && \
    tar -C /usr/local -xzf go.tar.gz && \
    rm go.tar.gz

ENV PATH="/usr/local/go/bin:${PATH}"

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build \
    -o bin/ai-services \
    -tags "${BUILDTAGS}" \
    -ldflags " \
    -X 'github.com/project-ai-services/ai-services/cmd/ai-services/cmd/version.Version=${CMD_VERSION}' \
    -X 'github.com/project-ai-services/ai-services/cmd/ai-services/cmd/version.GitCommit=${GITCOMMIT}' \
    -X 'github.com/project-ai-services/ai-services/cmd/ai-services/cmd/version.BuildDate=${BUILDDATE}' \
    " \
    ./cmd/ai-services

FROM registry.access.redhat.com/ubi9/ubi-minimal:9.8

# Install pciutils for lspci command (required for Spyre card detection)
RUN microdnf install -y pciutils && \
    microdnf clean all

# Create group with GID 1000 to match the VFIO device group ownership on the host
# The /dev/vfio/* devices are owned by group 1000 (as shown by ls -la /dev/vfio/)
# This allows the non-root user to access VFIO devices for Spyre card detection
RUN groupadd -f -g 1000 vfio && \
    useradd -u 1001 -g 0 -G vfio -m -s /bin/bash aiservices

COPY --from=builder /go/src/github.com/project-ai-services/ai-services/bin/ai-services /usr/bin/ai-services

USER 1001

EXPOSE 8080

ENTRYPOINT ["/usr/bin/ai-services"]
