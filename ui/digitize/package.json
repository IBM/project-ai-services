    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "esbuild": "^0.28.1",
    "@babel/core": ">=7.30.0",
