{
  "name": "catalog-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@carbon/ibm-products": "^2.84.0",
    "@carbon/icons-react": "^11.75.0",
    "@carbon/react": "^1.101.0",
    "axios": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.16.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.48.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "@babel/core": ">=7.30.0",
    "form-data": ">=4.0.6",
    "js-yaml": ">=4.1.2"
  }
}
